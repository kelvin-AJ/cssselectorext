{
  "name": "css-selector-generator",
  "displayName": "CSS selector generator [CSG]",
  "publisher": "OlamilekanAjibola",
  "description": "Generates CSS with all classes and ids of HTML file selected",
  "version": "2.1.0",
  "engines": {
    "vscode": "^1.71.0"
  },
  "categories": [
    "Formatters"
  ],
  "keywords": [
    "css",
    "CSS",
    "selector",
    "generator",
    "Generator",
    "CSS Selector",
    "css selector"
  ],
  "activationEvents": [
    "onCommand:css-selector-generator.initialize",
    "onFileSystem:css",
    "onLanguage:css",
    "onLanguage:js",
    "onLanguage:html",
    "onLanguage:jsp",
    "onLanguage:py",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:svelte",
    "onLanguage:scss",
    "onLanguage:less",
    "onLanguage:sass",
    "onStartupFinished"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kelvin-AJ/cssselectorext.git"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "css-selector-generator.generate",
        "title": "CSS Selector Generator"
      },
      {
        "command": "css-selector-generator.initialize",
        "title": "CSS Selector Initialize"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "css-selector-generator.generate",
          "when": "resourceLangId == css || resourceLangId == scss || resourceLangId == less || resourceLangId == sass",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "CSS Selector Generator",
      "properties": {
        "css-selector-generator.includeReset": {
          "type": "boolean",
          "default": true,
          "description": "Inject a global CSS reset (* { margin: 0; border: 0; }) into new CSS files."
        },
        "css-selector-generator.insertAtCursor": {
          "type": "boolean",
          "default": false,
          "description": "Insert generated selectors at the current cursor position instead of appending to the bottom."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "compile": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.71.0",
    "@vscode/test-electron": "^2.1.5",
    "esbuild": "^0.25.2",
    "eslint": "^8.20.0",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "typescript": "^4.7.4"
  },
  "icon": "img/icon.png",
  "packageManager": "pnpm@10.7.0+sha512.6b865ad4b62a1d9842b61d674a393903b871d9244954f652b8842c2b553c72176b278f64c463e52d40fff8aba385c235c8c9ecf5cc7de4fd78b8bb6d49633ab6"
}
